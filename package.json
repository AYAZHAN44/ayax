{
  "name": "dr-ayazhan-backend",
  "version": "1.0.0",
  "description": "DR.AYAZHAN clinic backend API with Node.js, Express and PostgreSQL.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:schema": "psql \"$DATABASE_URL\" -f database/schema.sql",
    "db:seed": "psql \"$DATABASE_URL\" -f database/seed.sql",
    "db:reset": "psql \"$DATABASE_URL\" -f database/reset.sql"
  },
  "keywords": [
    "clinic",
    "backend",
    "express",
    "postgresql"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
